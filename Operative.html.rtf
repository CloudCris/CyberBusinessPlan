        import \{ getFirestore, collection, addDoc, onSnapshot, query, doc, setDoc, getDoc, updateDoc, deleteDoc \} from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";\
\
        const firebaseConfig = JSON.parse(__firebase_config);\
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'operative-2026';\
        const apiKey = ""; \
        const app = initializeApp(firebaseConfig);\
        const auth = getAuth(app);\
        const db = getFirestore(app);\
        \
        let user = null;\
        let transactions = [];\
        let notes = [];\
        let dailyTasks = [];\
        let contacts = [];\
        let marketingEvents = [];\
        let activeDeals = [];\
        let propertyFolders = []; \
        let propertyLogs = []; \
        let kpi = \{ dials: 0, contacts: 0, appts: 0 \};\
        let currentLoad = 0;\
        let userProfile = \{ xp: 0, rank: 'INITIATE' \};\
        \
        let currentMktDate = new Date();\
        let selectedPropertyFilter = 'ALL';\
        let currentIntelId = null; \
        \
        const GOAL_GCI = 100000;\
        const GOAL_INVEST = 25000;\
        let protocolContent = [\
            \{ day: 0, label: "SUN [CALIBRATION]", schedule: [\{ time: "9:00 AM", cat: "MIND", text: "Visualize $100k GCI." \}] \},\
            \{ day: 1, label: "MON [ASSAULT_INIT]", schedule: [\{ time: "9:00 AM", cat: "HUNT", text: "POWER BLOCK: 50 Cold Calls." \}] \},\
            \{ day: 2, label: "TUE [TACTICAL_ADVANCE]", schedule: [\{ time: "8:00 AM", cat: "EDU", text: "TACS 3 Module Training." \}] \},\
            \{ day: 3, label: "WED [VISIBILITY_OPS]", schedule: [\{ time: "8:00 AM", cat: "MEDIA", text: "Film A-Roll content." \}] \},\
            \{ day: 4, label: "THU [NETWORK_EXPANSION]", schedule: [\{ time: "10:00 AM", cat: "HUNT", text: "Call Block: Past clients." \}] \},\
            \{ day: 5, label: "FRI [DEBRIEF_&_CLOSE]", schedule: [\{ time: "9:00 AM", cat: "KPI", text: "Weekly Audit." \}] \},\
            \{ day: 6, label: "SAT [STRATEGIC_RECON]", schedule: [\{ time: "9:00 AM", cat: "FIELD", text: "Drive-time recon." \}] \}\
        ];\
\
        const sleep = ms => new Promise(r => setTimeout(r, ms));\
        const safeAddClick = (id, handler) => \{ const el = document.getElementById(id); if (el) el.onclick = handler; \};\
\
        // --- WAR ROOM ---\
        let DEAL_STAGES = ['TARGET_ACQUIRED', 'RECON', 'ENGAGEMENT', 'INFILTRATION', 'MISSION_COMPLETE'];\
        \
        let currentEditStageIndex = -1;\
        window.openStageEditor = (index) => \{\
            currentEditStageIndex = index;\
            document.getElementById('edit-stage-input').value = DEAL_STAGES[index].replace(/_/g, ' ');\
            document.getElementById('stage-editor-modal').classList.remove('hidden');\
            document.getElementById('stage-editor-modal').classList.add('flex');\
        \};\
        \
        window.closeStageEditor = () => \{\
            document.getElementById('stage-editor-modal').classList.add('hidden');\
            document.getElementById('stage-editor-modal').classList.remove('flex');\
            currentEditStageIndex = -1;\
        \};\
\
        safeAddClick('btn-stage-cancel', window.closeStageEditor);\
        safeAddClick('btn-stage-save', async () => \{\
            if (currentEditStageIndex === -1 || !user) return;\
            let newName = document.getElementById('edit-stage-input').value.trim().toUpperCase().replace(/\\s+/g, '_');\
            if (!newName) return;\
\
            const oldName = DEAL_STAGES[currentEditStageIndex];\
            if (oldName === newName) \{ window.closeStageEditor(); return; \}\
\
            document.getElementById('btn-stage-save').innerText = 'UPDATING...';\
            DEAL_STAGES[currentEditStageIndex] = newName;\
            \
            try \{\
                await setDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'settings', 'warroom'), \{ stages: DEAL_STAGES \}, \{ merge: true \});\
                const dealsToUpdate = activeDeals.filter(d => d.stage === oldName);\
                for (let deal of dealsToUpdate) \{\
                    await updateDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'active_deals', deal.id), \{ stage: newName \});\
                \}\
                log(`COLUMN_RENAMED: $\{newName\}`, 'var(--neon-green)');\
                window.closeStageEditor();\
                renderWarRoom();\
            \} catch(e) \{\
                log('UPDATE_FAILED', 'red');\
            \} finally \{\
                document.getElementById('btn-stage-save').innerText = 'COMMIT';\
            \}\
        \});\
\
        window.addDeal = async () => \{ if (!user) return; const name = document.getElementById('deal-input-name').value; const val = parseInt(document.getElementById('deal-input-val').value); if (!name || isNaN(val)) return; try \{ await addDoc(collection(db, 'artifacts', appId, 'users', user.uid, 'active_deals'), \{ name, value: val, stage: DEAL_STAGES[0], timestamp: Date.now() \}); document.getElementById('deal-input-name').value = ''; document.getElementById('deal-input-val').value = ''; log(`TARGET_LOCKED: $\{name\}`, 'var(--neon-green)'); window.addXP(25); \} catch(e) \{ log('INJECTION_FAIL', 'red'); \} \};\
        window.moveDeal = async (id, currentStage, dir) => \{ if (!user) return; const currIdx = DEAL_STAGES.indexOf(currentStage); if(currIdx === -1) return; const newIdx = currIdx + dir; if (newIdx < 0 || newIdx >= DEAL_STAGES.length) return; const newStage = DEAL_STAGES[newIdx]; try \{ await updateDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'active_deals', id), \{ stage: newStage \}); playSFX('clunk'); if (newStage === DEAL_STAGES[DEAL_STAGES.length - 1]) \{ window.addXP(500); log(`MISSION_COMPLETE: TARGET_SECURED`, 'var(--neon-green)'); \} \} catch(e) \{\} \};\
        window.deleteDeal = async (id) => \{ if (!user) return; window.showConfirm("ABORT MISSION?", async () => \{ try \{ await deleteDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'active_deals', id)); \} catch(e) \{\} \}); \};\
        const renderWarRoom = () => \{ const board = document.getElementById('kanban-board'); if(!board) return; board.innerHTML = DEAL_STAGES.map((stage, index) => \{ const dealsInStage = activeDeals.filter(d => d.stage === stage); const totalVal = dealsInStage.reduce((acc, d) => acc + (d.value||0), 0); const cardsHtml = dealsInStage.map(d => ` <div class="kanban-card"> <div class="card-title">$\{d.name\}</div> <div class="card-val">$$\{d.value.toLocaleString()\}</div> <div class="card-controls"> $\{stage !== DEAL_STAGES[0] ? `<span class="card-btn" onclick="window.moveDeal('$\{d.id\}', '$\{stage\}', -1)">< PREV</span>` : '<span></span>'\} <span class="card-btn text-red-500" onclick="window.deleteDeal('$\{d.id\}')">X</span> $\{stage !== DEAL_STAGES[DEAL_STAGES.length - 1] ? `<span class="card-btn" onclick="window.moveDeal('$\{d.id\}', '$\{stage\}', 1)">NEXT ></span>` : '<span></span>'\} </div> </div> `).join(''); return ` <div class="kanban-col"> <div class="kanban-col-header group flex justify-between items-center"> <span>$\{stage.replace(/_/g, ' ')\} <span class="text-xs text-gray-500 font-normal">($$\{(totalVal/1000).toFixed(0)\}k)</span></span> <span class="cursor-pointer opacity-0 group-hover:opacity-100 text-neon-blue hover:text-neon-pink text-[10px]" onclick="window.openStageEditor($\{index\})">[\uc0\u9881 ]</span> </div> <div class="flex-1 overflow-y-auto custom-scrollbar">$\{cardsHtml\}</div> </div> `; \}).join(''); \};\
\
        // --- INTEL UPLINK (PROPERTY DB) ---\
        window.switchIntelTab = (tab, btn) => \{\
            document.querySelectorAll('.intel-tab').forEach(t => t.classList.remove('active'));\
            btn.classList.add('active');\
            ['data', 'logs', 'mkt'].forEach(t => document.getElementById(`intel-tab-$\{t\}`).classList.add('hidden'));\
            document.getElementById(`intel-tab-$\{tab\}`).classList.remove('hidden');\
            playSFX('clunk');\
            if(tab === 'mkt') renderPropertyMarketing();\
            if(tab === 'logs') renderPropertyLogs();\
        \};\
\
        // NEW: Add dynamic custom field row\
        window.addCustomField = (key = '', val = '') => \{\
            const container = document.getElementById('intel-custom-fields');\
            const id = 'cf_' + Date.now() + Math.floor(Math.random() * 1000);\
            const html = `\
                <div class="flex gap-2 items-center custom-field-row" id="$\{id\}">\
